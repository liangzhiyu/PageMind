{
  "manifest_version": 3,
  "name": "PageMind",
  "version": "1.0.0",
  "description": "AI-powered page summarization and chat assistant. Summarize any page and chat with custom AI models.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Open PageMind"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  }
}
